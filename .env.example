# Supabase 클라우드 프로젝트 키 — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server only — 절대 클라이언트 번들에 노출 금지. .gitignore 확인.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# 사이트 URL — 프로덕션이면 https://climb.example.kr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 구글 OAuth는 Supabase Dashboard → Auth → Providers → Google 에서 활성화
# 별도 .env 변수 불필요 (Supabase가 토큰 교환 처리)
